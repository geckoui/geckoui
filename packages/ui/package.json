{
  "name": "@geckoui/geckoui",
  "version": "1.5.1",
  "license": "MIT",
  "description": "The only thing our Gecko eats is bugs!",
  "keywords": ["react", "components", "ui", "library"],
  "repository": {
    "type": "git",
    "url": "https://github.com/geckoui/geckoui.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "dev": "node scripts/import-css.js && tsup --watch",
    "build": "node scripts/import-css.js && tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss}'"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/lodash.isequal": "^4.5.8",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "esbuild-sass-plugin": "^3.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^11.0.3",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "react-hook-form": "^7.66.0",
    "sass": "^1.94.0",
    "tailwindcss": "^4.1.17",
    "terser": "^5.44.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.28",
    "lodash.isequal": "^4.5.0",
    "mime": "^4.1.0",
    "react-textarea-autosize": "^8.5.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0"
  }
}
